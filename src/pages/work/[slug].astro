---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const entries = await getCollection("work", ({ data }) => !data.draft);

  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout title={entry.data.title} description={entry.data.summary}>
  <article class="section">
    <a class="back" href="/#projects"><span aria-hidden="true">&larr;</span> All projects</a>

    <header class="header">
      <h1>{entry.data.title}</h1>
      <p class="tagline">{entry.data.tagline}</p>
    </header>

    <div class="prose">
      <Content />
    </div>
  </article>
</BaseLayout>

<script>
  // Autoplay is a JS-only enhancement: without this script (or with reduced
  // motion preferred) the demo stays a static poster with native controls.
  const prefersReducedMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (!prefersReducedMotion) {
    document
      .querySelectorAll<HTMLVideoElement>('video[data-autoplay]')
      .forEach((video) => {
        video.muted = true;
        video.play().catch(() => {});
      });
  }
</script>

<style>
  .section {
    max-width: calc(var(--measure) + var(--space-4) * 2);
    margin-inline: auto;
    padding: var(--space-16) var(--space-4);
  }

  .back {
    display: inline-block;
    font-size: var(--text-sm);
    margin: 0 0 var(--space-8);
  }

  .header {
    margin: 0 0 var(--space-8);
  }

  h1 {
    font-size: var(--text-2xl);
    font-weight: 500;
    letter-spacing: var(--tracking-tight);
    line-height: var(--leading-snug);
    margin: 0 0 var(--space-4);
  }

  .tagline {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: var(--text-lg);
    color: var(--text-muted);
    margin: 0;
  }

  .prose :global(p) {
    font-size: var(--text-base);
    line-height: var(--leading-normal);
    color: var(--text-secondary);
    margin: 0 0 var(--space-6);
  }

  .prose :global(img) {
    display: block;
    width: 100%;
    height: auto;
    border-radius: var(--radius);
    border: 1px solid var(--border);
  }

  .prose :global(video) {
    display: block;
    width: 100%;
    height: auto;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    margin-block: var(--space-8);
  }

  .prose :global(p:has(> img)) {
    margin-block: var(--space-8);
  }

  .prose :global(blockquote) {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-style: normal;
    color: var(--text-muted);
    margin: var(--space-8) 0 0;
    padding: var(--space-6) 0 0;
    border-top: 1px solid var(--border);
  }

  .prose :global(blockquote p) {
    font-size: inherit;
    color: inherit;
    margin: 0;
  }
</style>
